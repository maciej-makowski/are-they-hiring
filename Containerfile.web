FROM python:3.12-slim
WORKDIR /app
COPY --from=ghcr.io/astral-sh/uv:latest /uv /bin/uv
COPY pyproject.toml uv.lock ./
COPY src/ src/
COPY alembic.ini ./
RUN uv sync --no-dev --frozen
EXPOSE 8000
CMD ["uv", "run", "uvicorn", "src.web.app:create_app", "--factory", "--host", "0.0.0.0", "--port", "8000"]
